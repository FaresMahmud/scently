{
  "name": "nozze",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev",
    "build": "prisma generate && next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "scrape": "npx ts-node scripts/scrape-perfumes.ts",
    "scrape:tendencias": "npx ts-node --project tsconfig.json scripts/scrape-tendencias.ts",
    "catalogo:popular": "npx ts-node -r tsconfig-paths/register --project tsconfig.scripts.json scripts/popular-catalogo.ts",
    "catalogo:continuar": "npx ts-node -r tsconfig-paths/register --project tsconfig.scripts.json scripts/popular-catalogo.ts --continuar",
    "contratipos:scrape": "npx ts-node -r tsconfig-paths/register --project tsconfig.scripts.json scripts/scrape-contratipos.ts",
    "contratipos:merge": "npx ts-node -r tsconfig-paths/register --project tsconfig.scripts.json scripts/merge-contratipos.ts",
    "catalog:expand": "npx ts-node -r tsconfig-paths/register --project tsconfig.scripts.json scripts/expand-catalog.ts",
    "catalog:expand:deepseek-ct": "npx ts-node -r tsconfig-paths/register --project tsconfig.scripts.json scripts/expand-catalog.ts --phase=deepseek-ct",
    "tendencias:editorial:seed": "npx ts-node -r tsconfig-paths/register --project tsconfig.scripts.json scripts/seed-tendencias-editorial.ts",
    "catalog:enrich": "npx ts-node -r tsconfig-paths/register --project tsconfig.scripts.json scripts/enrich-catalog-notes.ts",
    "editorial:enrich": "npx ts-node -r tsconfig-paths/register --project tsconfig.scripts.json scripts/enrich-perfume-editorial.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@sentry/nextjs": "^10.55.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/pg": "^8.20.0",
    "axios": "^1.16.1",
    "bcryptjs": "^3.0.3",
    "jose": "^6.2.3",
    "jsonwebtoken": "^9.0.3",
    "next": "16.2.6",
    "next-pwa": "^5.6.0",
    "pg": "^8.21.0",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "groq-sdk": "^1.2.1",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
