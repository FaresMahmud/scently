generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PerfumeStatus {
  TENHO
  JA_SENTI_GOSTEI
  QUERO_EXPERIMENTAR
}

enum Intensity {
  LEVE
  MODERADO
  INTENSO
  QUALQUER
}

model User {
  id                   String          @id @default(uuid())
  email                String          @unique
  passwordHash         String?
  provider             String          @default("credentials")
  googleId             String?         @unique
  name                 String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  failedLoginAttempts  Int             @default(0)
  lockedUntil          DateTime?
  refreshTokens        RefreshToken[]
  userPerfumes         UserPerfume[]
  userPreference       UserPreference?

  @@map("users")
}

model VerificationToken {
  id        String   @id @default(uuid())
  token     String   @unique
  email     String
  expires   DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@map("verification_tokens")
}

model RefreshToken {
  id        String    @id @default(uuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("refresh_tokens")
}

model UserPerfume {
  id          String        @id @default(uuid())
  userId      String
  perfumeId   String
  perfumeName String
  brand       String
  status      PerfumeStatus
  rating      Int?
  notes       String?
  addedAt     DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, perfumeId])
  @@index([userId])
  @@map("user_perfumes")
}

model UserPreference {
  id                String    @id @default(uuid())
  userId            String    @unique
  favoriteNotes     String[]
  avoidNotes        String[]
  favoriteOccasions String[]
  favoriteFamilies  String[]
  intensity         Intensity @default(QUALQUER)
  updatedAt         DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

model TendenciaEditorial {
  id           String   @id @default(uuid())
  categoria    String   // "inverno" | "primavera" | "global"
  titulo       String
  descricao    String
  ordem        Int
  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  sugestoes TendenciaEditorialSugestao[]

  @@unique([categoria, ordem])
  @@index([categoria])
  @@map("tendencias_editorial")
}

model TendenciaEditorialSugestao {
  id          String  @id @default(uuid())
  editorialId String  @map("editorial_id")
  genero      String  // "masculino" | "feminino" | "unissex"
  papel       String? // "base" | "topo" — exibido em vez do genero quando presente
  nome        String
  marca       String
  perfumeId   String? @map("perfume_id")

  editorial TendenciaEditorial @relation(fields: [editorialId], references: [id], onDelete: Cascade)

  @@map("tendencias_editorial_sugestoes")
}

model PerfumeEditorial {
  perfumeId      String   @id @map("perfume_id")
  comoCheira     String
  paraQuem       String
  quandoUsar     String
  comoSeComporta String
  geradoEm       DateTime @default(now()) @map("gerado_em")
  atualizadoEm   DateTime @updatedAt @map("atualizado_em")

  @@map("perfume_editorial")
}

model AnalyticsEvent {
  id        String   @id @default(uuid())
  tipo      String
  sessionId String   @map("session_id")
  userId    String?  @map("user_id")
  dados     Json?
  criadoEm DateTime @default(now()) @map("criado_em")

  @@index([tipo, criadoEm])
  @@index([criadoEm])
  @@map("analytics_events")
}

model Tendencia {
  id            String   @id @default(uuid())
  nome          String
  marca         String
  tipo          String   // "importado" | "contratipo" | "nacional"
  preco         String?
  badge         String?
  posicao       Int?
  fonte         String?
  descricao     String?  // copy editorial — fallback: "{nome} da {marca}."
  // Coluna existente no banco (de versão anterior do código) — mantida para não perder dados
  perfumeId     String?  @map("perfume_id")
  estacao       Boolean  @default(false)
  marcaDestaque Boolean  @default(false)
  ativo         Boolean  @default(true)
  pinned        Boolean  @default(false)
  tendencyScore Float?   @map("tendency_score")
  scrapedAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([nome, marca])
  @@index([scrapedAt])
  @@index([pinned, ativo])
  @@map("tendencias")
}

model TendenciaBlocklist {
  id        String   @id @default(uuid())
  nomeMarca String   @unique @map("nome_marca")
  motivo    String?
  criadoEm  DateTime @default(now()) @map("criado_em")

  @@map("tendencias_blocklist")
}
